# Database Settings
# Note: Inside Docker, the host is 'db' (the service name), not 'localhost'
DATABASE_URL=postgresql+asyncpg://your_user:your_password@db:5432/your_database_name

POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_database_name

# Server Settings
HOST=0.0.0.0
PORT=8000
PYTHON_VERSION=3.12.10

# Storage Settings
UPLOAD_TEMP_DIR=/app/data/uploads
TFIDF_INDEX_DIR=/app/data/indices

# Redis Settings
# Note: Inside Docker, the host is 'redis', not 'localhost'
REDIS_HOST=redis
REDIS_PORT=6379
TFIDF_QUEUE_NAME=tfidf_tasks

# Validation Settings (in bytes)
MAX_UPLOAD_SIZE=52428800
CHUNK_SIZE=1048576